{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information stored upon login.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "name": { "type": "string", "description": "Display name" },
        "email": { "type": "string", "format": "email", "description": "User email" },
        "photoURL": { "type": "string", "format": "uri", "description": "Profile photo URL" },
        "loginTime": { "type": "string", "format": "date-time", "description": "Last login timestamp" }
      },
      "required": ["uid", "name", "email", "loginTime"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile documents"
    }
  }
}
